# ══════════════════════════════════════════════════════════════
# OptimEngine x402 Gateway — Configuration
# ══════════════════════════════════════════════════════════════

# ── Your wallet address (0x... from Phantom on Base) ──
# This is where USDC payments will be received
WALLET_ADDRESS=0xYOUR_PHANTOM_BASE_ADDRESS_HERE

# ── OptimEngine MCP Server URL (Railway) ──
OPTIMENGINE_URL=https://optim-engine-production.up.railway.app

# ── Facilitator Configuration ──
# For TESTNET (no CDP account needed):
FACILITATOR_URL=https://x402.org/facilitator
NETWORK=eip155:84532

# For MAINNET (requires CDP API keys):
# FACILITATOR_URL=https://api.cdp.coinbase.com/platform/v2/x402
# NETWORK=eip155:8453
# CDP_API_KEY_ID=your_cdp_api_key_id
# CDP_API_KEY_SECRET=your_cdp_api_key_secret

# ── Server ──
PORT=4402
NODE_ENV=development
